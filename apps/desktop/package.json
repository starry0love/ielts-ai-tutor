{
  "name": "ielts-ai-tutor-desktop",
  "version": "0.1.0",
  "description": "Local IELTS AI tutor desktop app with user-provided AI API",
  "author": "Starry",
  "private": false,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "electron": "electron .",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "pack:dir": "electron-builder --dir",
    "pack:portable": "electron-builder --win portable",
    "pack:win": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.starry.ieltsaitutor",
    "productName": "IELTS AI Tutor",
    "npmRebuild": false,
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../../backend/dist/ielts-backend.exe",
        "to": "backend/ielts-backend.exe"
      }
    ],
    "win": {
      "target": "portable",
      "artifactName": "IELTS-AI-Tutor-Portable-${version}.${ext}",
      "signAndEditExecutable": false,
      "signDlls": false
    },
    "portable": {
      "artifactName": "IELTS-AI-Tutor-Portable-${version}.${ext}"
    }
  },
  "dependencies": {
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.7"
  }
}
